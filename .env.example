# EnGarde AI Environment Configuration
# Copy this file to .env and configure as needed

# ===================
# Video Processing
# ===================

# Maximum number of frames to process per video
MAX_VIDEO_FRAMES=300

# Video resize dimensions
VIDEO_WIDTH=640
VIDEO_HEIGHT=480

# ===================
# Analysis Settings
# ===================

# Angle difference threshold for "match" (degrees)
ANGLE_THRESHOLD=15.0

# DTW window radius for fast computation
DTW_RADIUS=1

# ===================
# MediaPipe Settings
# ===================

# Model complexity: 0=Lite, 1=Full, 2=Heavy
MEDIAPIPE_MODEL_COMPLEXITY=1

# Minimum confidence for pose detection (0.0-1.0)
MIN_DETECTION_CONFIDENCE=0.5

# Minimum confidence for pose tracking (0.0-1.0)
MIN_TRACKING_CONFIDENCE=0.5

# ===================
# UI Settings
# ===================

# Theme: dark or light
THEME=dark

# Page icon emoji
PAGE_ICON=🤺

# ===================
# Data Settings
# ===================

# Data directory
DATA_DIR=data

# Sessions directory for storing reports
SESSIONS_DIR=data/sessions

# Models directory for saved models
MODELS_DIR=data/models

# ===================
# Export Settings
# ===================

# Enable CSV export
EXPORT_CSV=true

# Enable video export
EXPORT_VIDEO=false

# ===================
# Performance Settings
# ===================

# Enable caching
ENABLE_CACHE=true

# Cache time-to-live in seconds
CACHE_TTL=3600

# ===================
# Logging Settings
# ===================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional, leave empty for console only)
LOG_FILE=
